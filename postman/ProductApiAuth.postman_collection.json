    {
      "name": "Day 04 - Refresh Token",
      "description": "Login, rotate refresh token, verify the old token is rejected, logout, then verify the logged-out token cannot be reused.",
      "item": [
        {
          "name": "01 - Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Login successful\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "const accessToken = response.data?.accessToken;",
                  "const refreshToken = response.data?.refreshToken;",
                  "",
                  "pm.test(\"Access token is returned\", function () {",
                  "    pm.expect(accessToken).to.be.a(\"string\").and.not.empty;",
                  "});",
                  "",
                  "pm.test(\"Refresh token is returned\", function () {",
                  "    pm.expect(refreshToken).to.be.a(\"string\").and.not.empty;",
                  "});",
                  "",
                  "if (accessToken) {",
                  "    pm.collectionVariables.set(\"day04AccessToken\", accessToken);",
                  "}",
                  "",
                  "if (refreshToken) {",
                  "    pm.collectionVariables.set(\"day04RefreshToken\", refreshToken);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "02 - Refresh And Rotate Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Refresh successful\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const previousRefreshToken = pm.collectionVariables.get(\"day04RefreshToken\");",
                  "const response = pm.response.json();",
                  "const accessToken = response.data?.accessToken;",
                  "const refreshToken = response.data?.refreshToken;",
                  "",
                  "pm.test(\"A new access token is returned\", function () {",
                  "    pm.expect(accessToken).to.be.a(\"string\").and.not.empty;",
                  "});",
                  "",
                  "pm.test(\"Refresh token is rotated\", function () {",
                  "    pm.expect(refreshToken).to.be.a(\"string\").and.not.empty;",
                  "    pm.expect(refreshToken).to.not.eql(previousRefreshToken);",
                  "});",
                  "",
                  "if (previousRefreshToken) {",
                  "    pm.collectionVariables.set(\"day04RevokedRefreshToken\", previousRefreshToken);",
                  "}",
                  "",
                  "if (accessToken) {",
                  "    pm.collectionVariables.set(\"day04AccessToken\", accessToken);",
                  "}",
                  "",
                  "if (refreshToken) {",
                  "    pm.collectionVariables.set(\"day04RefreshToken\", refreshToken);",
                  "}"
